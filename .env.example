# PostgreSQL connection URL for Prisma / backend (PROD)
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"
# Optional direct connection URL for Prisma migrations (PROD)
DIRECT_URL="postgresql://user:pass@host:5432/db?schema=public"

# Development overrides (used when NODE_ENV != production)
DEV_DATABASE_URL="postgresql://postgres:123@localhost:5432/smartsave?schema=public"
DEV_DB_DIRECT_URL="postgresql://postgres:123@localhost:5432/smartsave?schema=public"
DEV_DIRECT_URL="postgresql://postgres:123@localhost:5432/smartsave?schema=public"

# JWT configuration
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
ACCESS_TOKEN_TIME_ZONE="Europe/Zagreb"
REFRESH_TOKEN_TTL_MS="2592000000"

# CORS / app config
APP_PORT=4000
APP_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Development overrides (used when NODE_ENV != production)
DEV_APP_PORT=4000
DEV_APP_ORIGIN="http://localhost:3000"

# Optional Redis (recommended for multi-instance rate limiting)
REDIS_URL=""

# GitHub OAuth
GITHUB_CLIENT_ID="replace-with-github-client-id"
GITHUB_CLIENT_SECRET="replace-with-github-client-secret"
GITHUB_REDIRECT_URI="http://localhost:4000/auth/github/callback"

# Open Banking provider placeholders (Tink/Plaid-style)
OPEN_BANKING_PROVIDER="mock" # e.g. tink, plaid, trueLayer
OPEN_BANKING_CLIENT_ID="your-client-id"
OPEN_BANKING_CLIENT_SECRET="your-client-secret"
OPEN_BANKING_WEBHOOK_SECRET="your-webhook-secret"

